# Local development environment variables
# Copy this file to .env and fill values.

# Optional: EAS project id fallback (app.config.ts has built-in default)
EAS_PROJECT_ID=

# Optional: override app version for local/eas build
APP_VERSION=1.0.0

# Reverse geocode provider: amap | system
EXPO_PUBLIC_REVERSE_GEOCODE_PROVIDER=amap

# AMap Android SDK key (required on Android when using AMap native modules)
AMAP_ANDROID_API_KEY=

# AMap Web API key (required when geocode provider is amap)
EXPO_PUBLIC_AMAP_WEB_KEY=
