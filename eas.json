{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview-split": {
      "extends": "preview",
      "buildArtifactPaths": [
        "android/app/build/outputs/apk/release/*.apk"
      ],
      "android": {
        "buildType": "apk",
        "resourceClass": "large",
        "gradleCommand": ":app:assembleRelease -Pandroid.enableSeparateBuildPerCPUArchitecture=true -Dorg.gradle.parallel=false -Dorg.gradle.workers.max=2",
        "applicationArchivePath": "android/app/build/outputs/apk/release/*.apk"
      }
    },
    "preview-armeabi-v7a": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=armeabi-v7a"
      }
    },
    "preview-arm64-v8a": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      }
    },
    "preview-x86": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=x86"
      }
    },
    "preview-x86_64": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=x86_64"
      }
    },
    "production": {}
  }
}
